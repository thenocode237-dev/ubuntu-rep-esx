# =============================================================================
# Configuration de la plateforme Docker FiveM — copiez ce fichier en `.env`
# (`make install` le fait automatiquement) puis renseignez vos valeurs.
# TOUTE la configuration passe par ce fichier (SPECS §5 / §15).
# =============================================================================

# --- Serveur -----------------------------------------------------------------
SERVER_NAME=Ubuntu RP
SERVER_DESCRIPTION=Serveur Roleplay • ESX
# Nombre max de joueurs. DOIT être <= au quota de votre licence Cfx.re, sinon le
# serveur refuse les connexions ("allowed slot count is 48"). La clé gratuite =
# 48. Au-delà (64/128...) il faut un abonnement Cfx.re (FiveM Element Club).
MAX_CLIENTS=48
# Tags affichés dans le navigateur de serveurs (séparés par des virgules).
SV_TAGS=roleplay, français, esx

# --- Licence & artifacts FiveM -----------------------------------------------
# Clé de licence obtenue sur https://keymaster.fivem.net
LICENSE_KEY=
# Canal de build téléchargé automatiquement : recommended | latest
FIVEM_BUILD_CHANNEL=recommended
# Épingler un build précis : URL complète d'un fx.tar.xz (laisser vide = canal ci-dessus)
FIVEM_BUILD=
# Build GTA V imposé aux clients (ex: 2699, 2802, 3095, 3258...). Vide = par défaut.
GTA_BUILD=
# Mode de synchronisation réseau : on | legacy | off
ONESYNC=on

# --- Démarrage ---------------------------------------------------------------
# true  = piloté par txAdmin (interface web sur TXADMIN_PORT)
# false = headless, exécute directement le server.cfg généré
TXADMIN_ENABLE=true

# --- Ports (côté hôte) -------------------------------------------------------
FIVEM_PORT=30120
TXADMIN_PORT=40120

# --- Sécurité serveur --------------------------------------------------------
# Mot de passe RCON (administration distante). Laisser vide pour désactiver.
RCON_PASSWORD=change-me-rcon
# Clé Steam Web API (facultative) : https://steamcommunity.com/dev/apikey
STEAM_WEBAPI_KEY=

# --- MariaDB -----------------------------------------------------------------
MYSQL_DATABASE=fivem
MYSQL_USER=fivem
MYSQL_PASSWORD=change-me-db
MYSQL_ROOT_PASSWORD=change-me-root

# --- Redis -------------------------------------------------------------------
REDIS_PASSWORD=change-me-redis

# --- Couche RP (ESX) -----------------------------------------------------------
# Webhook Discord pour les logs/notifications des scripts (vide = désactivé).
DISCORD_WEBHOOK=

# --- Système -----------------------------------------------------------------
TZ=Europe/Paris

# =============================================================================
# V2 — Reverse proxy & monitoring (services opt-in via profils Compose).
#   Reverse proxy :  docker compose --profile proxy up -d      (ou make proxy)
#   Monitoring    :  docker compose --profile monitoring up -d (ou make monitoring)
# =============================================================================

# --- Nginx (reverse proxy) ---------------------------------------------------
HTTP_PORT=80
HTTPS_PORT=443

# --- Monitoring (Grafana) ----------------------------------------------------
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-grafana
