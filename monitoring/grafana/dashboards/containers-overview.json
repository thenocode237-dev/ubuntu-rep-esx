{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 0,
  "title": "Conteneurs — Vue d'ensemble",
  "uid": "fivem-containers",
  "schemaVersion": 39,
  "version": 1,
  "time": { "from": "now-6h", "to": "now" },
  "templating": { "list": [] },
  "panels": [
    {
      "type": "timeseries",
      "title": "CPU par conteneur (%)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "percent" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (name) (rate(container_cpu_usage_seconds_total{name!=\"\"}[5m])) * 100"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Mémoire par conteneur (octets)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (name) (container_memory_usage_bytes{name!=\"\"})"
        }
      ]
    },
    {
      "type": "logs",
      "title": "Logs (Loki)",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 9 },
      "targets": [
        { "refId": "A", "expr": "{container=~\".+\"}" }
      ]
    }
  ]
}
